---
import '../styles/global.css';
import type { Lang } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  lang?: Lang;
}

const { title, description, lang = 'en' } = Astro.props;
---

<!doctype html>
<html lang={lang} class="scroll-smooth" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Fineguide.ai" />
    <meta name="robots" content="index, follow" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://fineguide.ai/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={lang === 'ro' ? 'ro_RO' : 'en_US'} />
    <meta property="og:site_name" content="Fineguide.ai" />

    <meta name="theme-color" content="#f7f8fa" />
    <link rel="icon" type="image/png" href="/images/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="image" href="/images/hero-bg.jpg" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-17102198982" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-17102198982');
    </script>

<!-- Meta Pixel Code -->
<script>
!function(f,b,e,v,n,t,s)
{if(f.fbq)return;n=f.fbq=function(){n.callMethod?
n.callMethod.apply(n,arguments):n.queue.push(arguments)};
if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
n.queue=[];t=b.createElement(e);t.async=!0;
t.src=v;s=b.getElementsByTagName(e)[0];
s.parentNode.insertBefore(t,s)}(window, document,'script',
'https://connect.facebook.net/en_US/fbevents.js');
fbq('init', '895169123132914');
fbq('track', 'PageView');
</script>
<noscript><img height="1" width="1" style="display:none"
src="https://www.facebook.com/tr?id=895169123132914&ev=PageView&noscript=1"
/></noscript>
<!-- End Meta Pixel Code -->

  </head>
  <body class="min-h-screen">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:rounded-lg focus:bg-[var(--color-primary)] focus:text-white focus:text-sm focus:font-semibold">
      {lang === 'ro' ? 'Sari la conținut' : 'Skip to content'}
    </a>
    <slot />

    <script>
      const io = new IntersectionObserver(
        (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } }),
        { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>

    <script is:inline>
      (function() {
        function setLangPref(lang) {
          localStorage.setItem('fg-lang', lang);
          document.cookie = 'fg-lang=' + lang + ';path=/;max-age=31536000;SameSite=Lax';
        }

        var pref = localStorage.getItem('fg-lang');
        if (pref) {
          if (document.cookie.indexOf('fg-lang=') === -1) setLangPref(pref);
          return;
        }

        var path = window.location.pathname;
        var isRo = path.startsWith('/ro');
        var langs = navigator.languages || [navigator.language || ''];
        var wantsRo = langs.some(function(l) { return l.startsWith('ro'); });

        if (wantsRo && !isRo) {
          setLangPref('ro');
          window.location.replace('/ro' + (path === '/' ? '' : path));
        } else if (!wantsRo && isRo) {
          var enPath = path.replace(/^\/ro/, '') || '/';
          setLangPref('en');
          window.location.replace(enPath);
        } else {
          setLangPref(isRo ? 'ro' : 'en');
        }
      })();
    </script>
  </body>
</html>
