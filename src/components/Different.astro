---
import type { Translations } from '../i18n/utils';
const { t } = Astro.props as { t: Translations };
const steps = t.different.steps.map((s, i) => ({ num: String(i + 1).padStart(2, '0'), ...s }));
---

<section class="py-20 md:py-28 px-6 bg-[#1a1f2e] text-white dark-grain">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16">
      <div>
        <p class="text-sm font-medium uppercase tracking-widest text-[var(--color-primary-foreground)] opacity-60 mb-4">{t.different.label}</p>
        <h2 class="text-3xl md:text-5xl font-bold">{t.different.heading}</h2>
      </div>
      <p class="text-gray-400 text-lg mt-3 md:mt-0 max-w-md md:text-right">
        {t.different.subheading}
      </p>
    </div>

    {/* Desktop: horizontal workflow with arrows */}
    <div class="hidden lg:flex items-start justify-between">
      {steps.map((s, i) => (
        <div class="flex items-start" style={i < steps.length - 1 ? 'flex: 1;' : ''}>
          <div class="flex flex-col items-center text-center" style="min-width: 140px;">
            <div class="w-14 h-14 rounded-full border-2 border-white/20 flex items-center justify-center mb-4 bg-white/5">
              <span class="text-sm font-mono font-bold text-white">{s.num}</span>
            </div>
            <p class="text-base font-semibold mb-1.5">{s.label}</p>
            <p class="text-sm text-gray-400 leading-relaxed max-w-[150px]">{s.desc}</p>
          </div>
          {i < steps.length - 1 && (
            <div class="flex-1 flex items-center justify-center pt-7">
              <div class="w-full h-px bg-white/15 relative">
                <svg class="absolute -right-1 -top-1.5 w-3 h-3 text-white/30" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>

    {/* Tablet: 3-column grid */}
    <div class="hidden md:grid lg:hidden grid-cols-3 gap-y-10 gap-x-6">
      {steps.map((s, i) => (
        <div class="flex items-start gap-4">
          <div class="flex flex-col items-center shrink-0">
            <div class="w-12 h-12 rounded-full border-2 border-white/20 flex items-center justify-center bg-white/5">
              <span class="text-sm font-mono font-bold text-white">{s.num}</span>
            </div>
          </div>
          <div class="pt-1">
            <p class="text-base font-semibold mb-1">{s.label}</p>
            <p class="text-sm text-gray-400 leading-relaxed">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>

    {/* Mobile: vertical timeline */}
    <div class="md:hidden space-y-0">
      {steps.map((s, i) => (
        <div class="flex items-start gap-4">
          <div class="flex flex-col items-center shrink-0">
            <div class="w-12 h-12 rounded-full border-2 border-white/20 flex items-center justify-center bg-white/5">
              <span class="text-sm font-mono font-bold text-white">{s.num}</span>
            </div>
            {i < steps.length - 1 && (
              <div class="w-px h-8 bg-white/15"></div>
            )}
          </div>
          <div class="pt-2 pb-4">
            <p class="text-base font-semibold mb-1">{s.label}</p>
            <p class="text-sm text-gray-400 leading-relaxed">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
