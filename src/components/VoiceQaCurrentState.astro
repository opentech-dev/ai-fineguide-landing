---
import type { Translations } from '../i18n/utils';
const { t } = Astro.props as { t: Translations };

const problems = t.voiceQaCurrentState.problems;
---

<section class="py-20 md:py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row gap-12 md:gap-16 mb-12 reveal">
      <div class="md:w-5/12 md:sticky md:top-32 md:self-start">
        <p class="text-sm font-medium uppercase tracking-widest text-[var(--color-primary)] mb-4">{t.voiceQaCurrentState.label}</p>
        <h2 class="text-3xl md:text-4xl font-bold leading-tight">
          {t.voiceQaCurrentState.heading}
        </h2>
      </div>

      <div class="md:w-7/12">
        {problems.map((p: { title: string; desc: string }, i: number) => (
          <div class={`py-7 ${i < problems.length - 1 ? 'border-b border-[var(--color-border)]' : ''}`}>
            <div class="flex items-start gap-4">
              <span class="text-xs font-mono text-red-400 font-semibold pt-1 shrink-0">0{i + 1}</span>
              <div>
                <p class="text-lg font-semibold text-[var(--color-foreground)] mb-1">{p.title}</p>
                <p class="text-sm text-[var(--color-muted)] leading-relaxed">{p.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="text-center pt-12 pb-4">
      <div class="w-12 h-px bg-[var(--color-border)] mx-auto mb-10"></div>
      <p class="text-4xl md:text-6xl font-bold text-[var(--color-foreground)] mb-5" style="letter-spacing: -0.02em;">{t.voiceQaCurrentState.resultHeading}</p>
      <p class="text-[var(--color-muted)] text-xl md:text-2xl max-w-xl mx-auto leading-relaxed">
        {t.voiceQaCurrentState.resultText} <strong class="text-[var(--color-foreground)]">{t.voiceQaCurrentState.resultTextBold}</strong> {t.voiceQaCurrentState.resultTextEnd}
      </p>
    </div>
  </div>
</section>
