---
import type { Translations } from '../i18n/utils';
const { t } = Astro.props as { t: Translations };

const icons = [
  '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />',
];

const criteria = t.voiceQaAudience.criteria.map((text: string, i: number) => ({
  icon: icons[i],
  text,
}));
---

<section id="pentru-cine" class="py-20 md:py-32 px-6 bg-[#f5f3ef]">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-sm font-medium uppercase tracking-widest text-[var(--color-primary)] mb-4">{t.voiceQaAudience.label}</p>
      <h2 class="text-3xl md:text-5xl font-bold mb-4">{t.voiceQaAudience.heading}</h2>
      <p class="text-[var(--color-muted)] text-lg">{t.voiceQaAudience.subheading}</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
      {criteria.map((c: { icon: string; text: string }) => (
        <div class="bg-white rounded-xl p-6 flex items-center gap-4 border border-[#e0dbd4] shadow-sm">
          <div class="icon-circle bg-gray-100 text-gray-600">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" set:html={c.icon} />
          </div>
          <span>{c.text}</span>
        </div>
      ))}
    </div>

    <p class="text-center text-[var(--color-muted)] text-lg max-w-2xl mx-auto">
      {t.voiceQaAudience.closingText}
      <span class="text-[var(--color-foreground)] font-medium"> {t.voiceQaAudience.closingAccent}</span>
    </p>
  </div>
</section>
