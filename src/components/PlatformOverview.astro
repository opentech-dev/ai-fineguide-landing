---
import type { Translations } from '../i18n/utils';
import { getLocalizedPath } from '../i18n/utils';
const { t, lang = 'en' } = Astro.props as { t: Translations; lang?: string };
const moduleIcons = [
  '<path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />',
];
const moduleHrefs = [getLocalizedPath('/', lang), null, getLocalizedPath('/voice-qa', lang), null];
---

<section id="platforma" class="py-20 md:py-32 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16 reveal">
      <p class="text-sm font-medium uppercase tracking-widest text-[var(--color-primary)] mb-4">{t.platform.label}</p>
      <h2 class="text-3xl md:text-5xl font-bold mb-4">{t.platform.heading}</h2>
      <p class="text-[var(--color-muted)] text-lg max-w-2xl mx-auto">
        {t.platform.subheading}
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-5">
      {t.platform.modules.map((m, i) => {
        const href = moduleHrefs[i];
        const Tag = href ? 'a' : 'div';
        return (
          <Tag
            href={href}
            class={`bg-white rounded-2xl p-8 border border-[var(--color-border)] shadow-sm card-hover reveal ${href ? 'group' : ''}`}
          >
            <div class="flex items-center gap-3 mb-3">
              <div class="icon-circle icon-circle-primary w-10 h-10 rounded-xl">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" set:html={moduleIcons[i]} />
              </div>
              <h3 class="text-lg font-semibold">
                {m.title}
                {href && (
                  <svg class="inline w-4 h-4 ml-1 opacity-0 -translate-x-1 group-hover:opacity-60 group-hover:translate-x-0 transition-all" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                )}
              </h3>
            </div>
            <p class="text-[var(--color-muted)] leading-relaxed mb-3">{m.desc}</p>
            <div class="flex flex-wrap gap-1.5">
              {m.tags.map((tag: string) => (
                <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 text-[var(--color-muted)] font-medium">{tag}</span>
              ))}
            </div>
          </Tag>
        );
      })}
    </div>
  </div>
</section>
