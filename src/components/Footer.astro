---
import type { Translations, Lang } from '../i18n/utils';
import { getLocalizedPath, switchLangPath } from '../i18n/utils';
const { t, lang = 'en' } = Astro.props as { t: Translations; lang?: string };

const currentPath = Astro.url.pathname;
const otherLang: Lang = lang === 'ro' ? 'en' : 'ro';
const switchPath = switchLangPath(currentPath, otherLang);
---

<footer class="border-t border-[var(--color-border)]/50 py-12 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row items-start justify-between gap-8 mb-8">
      <div>
        <img src="/images/logo/fineguide_lg.svg" alt="Fineguide.ai" class="h-7" />
        <p class="text-sm text-[var(--color-muted)] mt-2 max-w-xs">
          {t.footer.tagline}
        </p>
      </div>
      <div class="flex gap-12">
        <div>
          <p class="text-sm font-semibold text-[var(--color-foreground)] mb-3">{t.footer.product}</p>
          <div class="flex flex-col gap-2">
            <a href={getLocalizedPath('/', lang)} class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">{t.nav.aiAgents}</a>
            <a href={getLocalizedPath('/voice-qa', lang)} class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">{t.nav.voiceQa}</a>
            <a href={getLocalizedPath('/pricing', lang)} class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">{t.nav.pricing}</a>
          </div>
        </div>
        <div>
          <p class="text-sm font-semibold text-[var(--color-foreground)] mb-3">{t.footer.company}</p>
          <div class="flex flex-col gap-2">
            <a href={getLocalizedPath('/schedule-demo', lang)} class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">{t.footer.scheduleDemo}</a>
            <a href={getLocalizedPath('/contact', lang)} class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">{t.footer.contact}</a>
          </div>
        </div>
      </div>
    </div>
    <div class="border-t border-[var(--color-border)]/50 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-sm text-[var(--color-muted)]">
        &copy; {new Date().getFullYear()} Fineguide.ai. {t.footer.copyright}
      </p>
      <div class="flex items-center gap-4">
        <a href={getLocalizedPath('/privacy-policy', lang)} class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">{t.footer.privacy}</a>
        <a href={getLocalizedPath('/terms-of-service', lang)} class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">{t.footer.terms}</a>
        <span class="text-[var(--color-border)]">|</span>
        <a
          href={switchPath}
          onclick={`localStorage.setItem('fg-lang','${otherLang}')`}
          class="inline-flex items-center gap-1.5 text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A8.966 8.966 0 0 1 3 12c0-1.264.26-2.467.732-3.558" /></svg>
          {otherLang === 'ro' ? 'Română' : 'English'}
        </a>
      </div>
    </div>
  </div>
</footer>
