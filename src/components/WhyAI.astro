---
const points = [
  { icon: '<path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />', title: 'Răspunde instant', desc: 'Nicio conversație pierdută, indiferent de oră.' },
  { icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />', title: 'Înțelege intenția', desc: 'Nu urmează scripturi rigide adaptează conversația.' },
  { icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />', title: 'Analizează apeluri', desc: 'Extrage insight-uri din fiecare interacțiune.' },
  { icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />', title: 'Optimizează procesul', desc: 'Identifică blocajele și sugerează îmbunătățiri.' },
];
---

<section class="py-16 md:py-24 px-6 border-t border-[var(--color-border)]">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16 reveal">
      <p class="text-sm font-medium uppercase tracking-widest text-[var(--color-primary)] mb-4">De ce AI</p>
      <h2 class="text-3xl md:text-5xl font-bold mb-4">De ce AI face diferența</h2>
      <p class="text-[var(--color-muted)] text-lg max-w-2xl mx-auto">
        Automatizarea clasică urmează reguli fixe. AI gândește, adaptează și optimizează.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-5 mb-12">
      {points.map((p) => (
        <div class="bg-white rounded-2xl p-8 border border-[var(--color-border)] shadow-sm card-hover reveal">
          <div class="icon-circle icon-circle-primary w-12 h-12 rounded-xl mb-5">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" set:html={p.icon} />
          </div>
          <h3 class="text-xl font-semibold mb-2">{p.title}</h3>
          <p class="text-[var(--color-muted)] leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>

    <div class="flex items-center justify-center gap-3 bg-white rounded-2xl p-6 border border-[var(--color-border)] shadow-sm reveal">
      <div class="icon-circle icon-circle-primary">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
        </svg>
      </div>
      <p class="text-lg font-medium">
        Crești capacitatea echipei fără să mărești numărul de angajați.
      </p>
    </div>
  </div>
</section>
