---
import type { Translations } from '../i18n/utils';
import { getLocalizedPath } from '../i18n/utils';
const { t, lang } = Astro.props as { t: Translations; lang: string };
---

<section class="py-16 md:py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="border border-[var(--color-border)] rounded-2xl p-8 md:p-12 flex flex-col md:flex-row items-start md:items-center gap-8">
      <div class="flex-1">
        <h3 class="text-2xl font-bold mb-3">{t.pricingEnterprise.heading}</h3>
        <p class="text-[var(--color-muted)] mb-6 max-w-xl">
          {t.pricingEnterprise.subtitle}
        </p>
        <ul class="space-y-2">
          {t.pricingEnterprise.features.map((feature: string) => (
            <li class="flex items-center gap-2 text-sm text-[var(--color-muted)]">
              <svg class="w-4 h-4 text-emerald-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
              {feature}
            </li>
          ))}
        </ul>
      </div>
      <div class="shrink-0">
        <a
          href={getLocalizedPath('/contact', lang)}
          class="inline-flex items-center gap-2 px-8 py-3.5 text-sm font-semibold text-white bg-[var(--color-primary)] hover:opacity-90 rounded-xl transition-all"
        >
          {t.pricingEnterprise.cta}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </div>
</section>
