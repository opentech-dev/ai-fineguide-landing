---
import type { Translations } from '../i18n/utils';
const { t } = Astro.props as { t: Translations };

const plans = [
  {
    name: 'Starter',
    price: '$99',
    credits: '10.000',
    extraCreditsPrice: '$15 / 1.000',
    popular: false,
  },
  {
    name: 'Business',
    price: '$199',
    credits: '23.000',
    extraCreditsPrice: '$12 / 1.000',
    popular: true,
  },
  {
    name: 'Premium',
    price: '$499',
    credits: '65.000',
    extraCreditsPrice: '$10 / 1.000',
    popular: false,
  },
];

const modules = ['AI Agents', 'CRM', 'Voice QA', 'n8n Workflows', 'Analytics', 'Integrări'];
---

<section class="py-20 md:py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid lg:grid-cols-3 gap-6">
      {plans.map((plan, i) => (
        <div class={`relative rounded-2xl border ${plan.popular ? 'border-[var(--color-primary)] shadow-md' : 'border-[var(--color-border)] shadow-sm'} bg-white overflow-hidden`}>
          {plan.popular && (
            <div class="absolute top-0 left-0 right-0 bg-[var(--color-primary)] text-white text-xs font-semibold text-center py-1.5 uppercase tracking-wider">
              {t.pricingPlans.mostPopular}
            </div>
          )}

          <div class={`p-8 ${plan.popular ? 'pt-12' : ''}`}>
            <h3 class="text-2xl font-bold mb-1">{plan.name}</h3>
            <p class="text-sm text-[var(--color-muted)] mb-6">{t.pricingPlans.plans[i].desc}</p>

            <div class="flex items-baseline gap-1 mb-1">
              <span class="text-4xl font-bold text-[var(--color-foreground)]">{plan.price}</span>
              <span class="text-[var(--color-muted)] text-sm">{t.pricingPlans.perMonth}</span>
            </div>

            <!-- Credits box -->
            <div class="bg-[#f5f3ef] rounded-xl p-4 my-6">
              <div class="flex items-center justify-between mb-1">
                <span class="text-sm font-medium text-[var(--color-foreground)]">{t.pricingPlans.monthlyCredits}</span>
                <span class="text-xl font-bold text-[var(--color-foreground)]">{plan.credits}</span>
              </div>
              <p class="text-xs text-[var(--color-muted)] mb-1">{t.pricingPlans.extraCredits}{plan.extraCreditsPrice}</p>
              <p class="text-xs text-[var(--color-muted)]">{t.pricingPlans.plans[i].credits}</p>
            </div>

            <!-- Team & features -->
            <div class="space-y-3 mb-6">
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 text-[var(--color-foreground)] shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
                <span class="text-sm font-medium">{t.pricingPlans.plans[i].features[0]}</span>
              </div>
              {t.pricingPlans.plans[i].features.slice(1).map((f: string) => (
                <div class="flex items-center gap-3">
                  <svg class="w-4 h-4 text-emerald-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  <span class="text-sm text-[var(--color-muted)]">{f}</span>
                </div>
              ))}
            </div>

            <!-- Modules -->
            <div class="mb-8">
              <p class="text-xs font-medium uppercase tracking-wider text-[var(--color-muted)] mb-3">{t.pricingPlans.modulesIncluded}</p>
              <div class="flex flex-wrap gap-1.5">
                {modules.map((m) => (
                  <span class="text-xs px-2.5 py-1 rounded-md bg-gray-100 text-[var(--color-muted)] font-medium">{m}</span>
                ))}
              </div>
            </div>

            <a
              href="https://app.fineguide.ai/register"
              class={`w-full flex items-center justify-center gap-2 px-6 py-3.5 text-sm font-semibold rounded-xl transition-all ${
                plan.popular
                  ? 'text-white bg-[var(--color-primary)] hover:opacity-90'
                  : 'text-[var(--color-foreground)] bg-white border border-[var(--color-border)] hover:border-[#d1d5e0]'
              }`}
            >
              {t.pricingPlans.ctaButton}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
