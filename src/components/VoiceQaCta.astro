---
import type { Translations } from '../i18n/utils';
import { getLocalizedPath } from '../i18n/utils';
const { t, lang } = Astro.props as { t: Translations; lang: string };
---

<section class="py-20 md:py-32 px-6 bg-[#1a1f2e] text-white dark-grain">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl md:text-5xl font-bold mb-6">
      {t.voiceQaCta.heading}
      <span class="text-[var(--color-primary-foreground)]"> {t.voiceQaCta.headingAccent}</span>{t.voiceQaCta.headingSuffix}
    </h2>
    <p class="text-gray-400 text-lg mb-10">
      {t.voiceQaCta.subtitle}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="https://app.fineguide.ai/login"
        class="inline-flex items-center justify-center gap-2 px-10 py-4 text-base font-semibold text-white bg-[var(--color-primary)] hover:opacity-90 rounded-xl transition-all"
      >
        {t.voiceQaCta.ctaPrimary}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
      </a>
      <a
        href={getLocalizedPath('/schedule-demo', lang)}
        class="inline-flex items-center justify-center gap-2 px-10 py-4 text-base font-semibold text-white border border-white/20 hover:border-white/40 rounded-xl transition-all"
      >
        {t.voiceQaCta.ctaSecondary}
      </a>
    </div>
    <p class="mt-8 text-sm text-gray-500 flex items-center justify-center gap-4">
      {t.voiceQaCta.features.map((feature: string) => (
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
          {feature}
        </span>
      ))}
    </p>
  </div>
</section>
