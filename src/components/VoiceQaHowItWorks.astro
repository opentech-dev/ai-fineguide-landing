---
import type { Translations } from '../i18n/utils';
const { t } = Astro.props as { t: Translations };

const images = [
  '/images/steps/step-voiceqa-01.jpg',
  '/images/steps/step-voiceqa-02.jpg',
  '/images/steps/step-voiceqa-03.jpg',
  '/images/steps/step-voiceqa-04.jpg',
  '/images/steps/step-voiceqa-05.jpg',
];

const steps = t.voiceQaHowItWorks.steps.map((s: { title: string; desc: string }, i: number) => ({
  num: String(i + 1).padStart(2, '0'),
  image: images[i],
  ...s,
}));
---

<section id="cum-functioneaza" class="pt-16 pb-20 md:pt-28 md:pb-40 px-6 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-20">
      <p class="text-sm font-medium uppercase tracking-widest text-[var(--color-primary)] mb-4">{t.voiceQaHowItWorks.label}</p>
      <h2 class="text-3xl md:text-5xl font-bold">{t.voiceQaHowItWorks.heading}</h2>
    </div>

    <div class="space-y-20 md:space-y-32">
      {steps.map((s: { num: string; image: string; title: string; desc: string }, i: number) => {
        const isEven = i % 2 === 0;
        return (
          <div>
            <div class={`flex flex-col gap-8 ${isEven ? 'md:flex-row' : 'md:flex-row-reverse'} items-center`}>
              <div class="w-full md:w-[60%]">
                <div class="rounded-2xl overflow-hidden border border-[var(--color-border)]">
                  <img
                    src={s.image}
                    alt={s.title}
                    class="w-full h-72 md:h-[28rem] object-cover"
                    loading="lazy"
                  />
                </div>
              </div>

              <div class="w-full md:w-[40%]">
                <div class="flex items-center gap-3 mb-3 md:hidden">
                  <span class="inline-flex w-9 h-9 rounded-full bg-[var(--color-primary)] text-white items-center justify-center font-mono text-xs font-bold">
                    {s.num}
                  </span>
                  <h3 class="text-2xl font-bold">{s.title}</h3>
                </div>
                <span class="hidden md:inline-block text-sm font-mono text-[var(--color-primary)] font-semibold mb-3 tracking-wider">{t.voiceQaHowItWorks.stepPrefix} {s.num}</span>
                <h3 class="hidden md:block text-2xl md:text-3xl font-bold mb-4">{s.title}</h3>
                <p class="text-[var(--color-muted)] text-lg leading-relaxed">{s.desc}</p>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
